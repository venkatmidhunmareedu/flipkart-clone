PORT=5000
# Comma-separated frontend origins allowed for CORS (no trailing slash).
# Exact match: https://flipkart-clone-frontend-ten.vercel.app
# Wildcard for all Vercel previews: https://*.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://*.vercel.app
# Alias supported: CORS_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
JWT_SECRET=your-jwt-secret-min-32-chars
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
GMAIL_USER=
GMAIL_APP_PASSWORD=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
